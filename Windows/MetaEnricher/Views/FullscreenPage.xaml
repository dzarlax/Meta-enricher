<Page
    x:Class="MetaEnricher.Views.FullscreenPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark"
    Background="#000000"
    KeyDown="Page_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Grid
            Grid.Row="0"
            Padding="16,12,154,12"
            Background="#0A0A0A"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Prev / Next -->
            <Button
                Grid.Column="0"
                Content="← Prev"
                Click="BtnPrev_Click"
                Background="Transparent"
                Foreground="#9CA3AF"
                BorderBrush="#3A3A3A"
                FontSize="13"
                Padding="10,6" />
            <Button
                Grid.Column="1"
                Content="Next →"
                Click="BtnNext_Click"
                Background="Transparent"
                Foreground="#9CA3AF"
                BorderBrush="#3A3A3A"
                FontSize="13"
                Padding="10,6" />

            <!-- Filename -->
            <TextBlock
                x:Name="TbFilename"
                Grid.Column="2"
                Foreground="#F5F5F5"
                FontSize="14"
                FontWeight="Medium"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                TextTrimming="CharacterEllipsis" />

            <!-- Rotate CCW -->
            <Button
                Grid.Column="3"
                Content="↺"
                ToolTipService.ToolTip="Rotate counter-clockwise (Shift+R)"
                Click="BtnRotateCCW_Click"
                Background="Transparent"
                Foreground="#9CA3AF"
                BorderBrush="#3A3A3A"
                FontSize="18"
                Padding="8,4" />

            <!-- Rotate CW -->
            <Button
                Grid.Column="4"
                Content="↻"
                ToolTipService.ToolTip="Rotate clockwise (R)"
                Click="BtnRotateCW_Click"
                Background="Transparent"
                Foreground="#9CA3AF"
                BorderBrush="#3A3A3A"
                FontSize="18"
                Padding="8,4" />

            <!-- Close -->
            <Button
                Grid.Column="5"
                Content="✕"
                ToolTipService.ToolTip="Close (Escape)"
                Click="BtnClose_Click"
                Background="Transparent"
                Foreground="#9CA3AF"
                BorderBrush="#3A3A3A"
                FontSize="14"
                Padding="10,6" />
        </Grid>

        <!-- Main image area -->
        <Image
            x:Name="FullscreenImage"
            Grid.Row="1"
            Stretch="Uniform"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Tapped="FullscreenImage_Tapped"
            ToolTipService.ToolTip="← → navigate · R rotate · Esc close" />

        <!-- Bottom EXIF overlay -->
        <Border
            Grid.Row="2"
            Background="#0A0A0A"
            Padding="16,10">
            <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
                <TextBlock x:Name="LblDate" Foreground="#9CA3AF" FontSize="12" />
                <TextBlock x:Name="LblCamera" Foreground="#9CA3AF" FontSize="12" />
                <TextBlock x:Name="LblFocal" Foreground="#9CA3AF" FontSize="12" />
                <TextBlock x:Name="LblAperture" Foreground="#9CA3AF" FontSize="12" />
                <TextBlock x:Name="LblShutter" Foreground="#9CA3AF" FontSize="12" />
                <TextBlock x:Name="LblIso" Foreground="#9CA3AF" FontSize="12" />
                <TextBlock
                    Foreground="#6B7280"
                    FontSize="11">
                    <Run Text="Keyboard: ← → navigate  |  R rotate CW  |  Shift+R rotate CCW  |  Esc close" />
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>
