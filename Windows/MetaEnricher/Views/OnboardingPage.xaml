<Page
    x:Class="MetaEnricher.Views.OnboardingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark"
    Background="#1A1A1A">

    <Grid>
        <!-- Step 0: Welcome -->
        <StackPanel
            x:Name="StepWelcome"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="24"
            MaxWidth="480">

            <!-- Logo area -->
            <Border
                Width="96" Height="96"
                CornerRadius="24"
                Background="#2D2D2D"
                HorizontalAlignment="Center">
                <TextBlock
                    Text="📷"
                    FontSize="48"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Border>

            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock
                    Text="Meta Enricher"
                    FontSize="36"
                    FontWeight="Bold"
                    Foreground="#F5F5F5"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="AI-powered photo metadata enrichment"
                    FontSize="16"
                    Foreground="#9CA3AF"
                    HorizontalAlignment="Center" />
            </StackPanel>

            <Button
                x:Name="BtnGetStarted"
                Content="Get Started"
                HorizontalAlignment="Center"
                Padding="32,14"
                FontSize="16"
                Click="BtnGetStarted_Click"
                Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>

        <!-- Step 1: Library Setup -->
        <StackPanel
            x:Name="StepLibrary"
            Visibility="Collapsed"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="24"
            MaxWidth="520"
            Padding="32">

            <!-- Progress dots -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <Ellipse Width="8" Height="8" Fill="#3A3A3A" />
                <Ellipse Width="8" Height="8" Fill="#FFB938" />
                <Ellipse Width="8" Height="8" Fill="#3A3A3A" />
            </StackPanel>

            <TextBlock
                Text="Set Up Your Library"
                FontSize="28"
                FontWeight="Bold"
                Foreground="#F5F5F5"
                HorizontalAlignment="Center" />

            <TextBlock
                Text="Select your photo library root folder. The app expects a Year → Date → Subfolder structure."
                TextWrapping="Wrap"
                Foreground="#9CA3AF"
                HorizontalAlignment="Center"
                TextAlignment="Center" />

            <!-- Folder picker -->
            <Border Background="#242424" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Photo Library Root" Foreground="#9CA3AF" FontSize="12" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="TbSelectedPath"
                            Text="No folder selected"
                            Foreground="#6B7280"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis" />
                        <Button
                            Grid.Column="1"
                            Content="Browse"
                            Click="BtnBrowse_Click"
                            Style="{StaticResource OutlineButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Folder structure preview -->
            <Border Background="#1E1E1E" CornerRadius="8" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Expected folder structure:" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,8" />
                    <TextBlock Text="Root/" Foreground="#F5F5F5" FontFamily="Consolas" FontSize="13" />
                    <TextBlock Text="  2026/" Foreground="#9CA3AF" FontFamily="Consolas" FontSize="13" />
                    <TextBlock Text="    2026-03-07 [label]/" Foreground="#9CA3AF" FontFamily="Consolas" FontSize="13" />
                    <TextBlock x:Name="TbFolderStructure" Text="      Edited export/  ← editable JPEGs" Foreground="#FFB938" FontFamily="Consolas" FontSize="13" />
                    <TextBlock Text="      JPEG/  ← originals" Foreground="#6B7280" FontFamily="Consolas" FontSize="13" />
                    <TextBlock Text="      RAW/" Foreground="#6B7280" FontFamily="Consolas" FontSize="13" />
                </StackPanel>
            </Border>

            <!-- Custom subfolder name -->
            <StackPanel Spacing="8">
                <TextBlock Text="Picks subfolder name" Foreground="#9CA3AF" FontSize="12" />
                <TextBox
                    x:Name="TbPicksFolderName"
                    PlaceholderText="Edited export"
                    Text="Edited export"
                    Background="#242424"
                    BorderBrush="#3A3A3A"
                    Foreground="#F5F5F5"
                    TextChanged="TbPicksFolderName_TextChanged" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                <Button Content="Back" Click="BtnBack_Click" Background="Transparent" Foreground="#9CA3AF" />
                <Button
                    x:Name="BtnContinue"
                    Content="Continue"
                    IsEnabled="False"
                    Click="BtnContinue_Click"
                    Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </StackPanel>

        <!-- Step 2: Done -->
        <StackPanel
            x:Name="StepDone"
            Visibility="Collapsed"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="24"
            MaxWidth="480"
            Padding="32">

            <!-- Progress dots -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <Ellipse Width="8" Height="8" Fill="#3A3A3A" />
                <Ellipse Width="8" Height="8" Fill="#3A3A3A" />
                <Ellipse Width="8" Height="8" Fill="#FFB938" />
            </StackPanel>

            <Border
                Width="80" Height="80"
                CornerRadius="40"
                Background="#1A3A1A"
                HorizontalAlignment="Center">
                <TextBlock
                    Text="✓"
                    FontSize="40"
                    Foreground="#22C55E"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Border>

            <TextBlock
                Text="You're all set!"
                FontSize="28"
                FontWeight="Bold"
                Foreground="#F5F5F5"
                HorizontalAlignment="Center" />

            <TextBlock
                Text="Your library is configured. Start enriching your photos with AI-generated metadata."
                TextWrapping="Wrap"
                Foreground="#9CA3AF"
                HorizontalAlignment="Center"
                TextAlignment="Center" />

            <Button
                Content="Open Library"
                HorizontalAlignment="Center"
                Padding="32,14"
                FontSize="16"
                Click="BtnOpenLibrary_Click"
                Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Page>
