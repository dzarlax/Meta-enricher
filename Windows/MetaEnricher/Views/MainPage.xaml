<Page
    x:Class="MetaEnricher.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MetaEnricher.Models"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    RequestedTheme="Dark"
    Background="#1A1A1A">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════ LEFT PANEL ═══════════════════════════ -->
        <Grid Grid.Column="0" Background="#242424">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="16,14,16,10" BorderThickness="0,0,0,1" BorderBrush="#3A3A3A">
                <TextBlock
                    Text="Sessions"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#F5F5F5" />
            </Border>

            <!-- Sessions list -->
            <ListView
                x:Name="SessionsList"
                Grid.Row="1"
                ItemsSource="{x:Bind AppState.Sessions, Mode=OneWay}"
                SelectedItem="{x:Bind AppState.SelectedSession, Mode=TwoWay}"
                SelectionMode="Single"
                Background="Transparent"
                Padding="4,0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="CornerRadius" Value="6" />
                        <Setter Property="UseSystemFocusVisuals" Value="False" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:PhotoSession">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Thumbnail -->
                            <Border
                                Width="48" Height="48"
                                CornerRadius="6"
                                Background="#2D2D2D">
                                <Image
                                    Source="{x:Bind ThumbnailSource, Mode=OneWay}"
                                    Stretch="UniformToFill" />
                            </Border>

                            <!-- Info -->
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock
                                    Text="{x:Bind DisplayName}"
                                    FontSize="13"
                                    FontWeight="Medium"
                                    Foreground="#F5F5F5"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind ActiveCountDisplay, Mode=OneWay}"
                                    FontSize="11"
                                    Foreground="#9CA3AF"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <!-- Status dot -->
                            <Ellipse
                                Grid.Column="2"
                                Width="8" Height="8"
                                VerticalAlignment="Center"
                                Fill="{x:Bind EnrichmentStatus, Converter={StaticResource EnrichmentStatusToColor}}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Bottom: buttons + library path -->
            <StackPanel Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#3A3A3A" Spacing="0">
                <Button
                    Content="↻  Refresh Sessions"
                    Click="BtnRefreshSessions_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    Foreground="#D1D5DB"
                    BorderThickness="0"
                    Padding="16,12"
                    FontSize="13" />
                <Button
                    Content="⤓  Import Photos"
                    Click="BtnImport_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    Foreground="#D1D5DB"
                    BorderThickness="0"
                    Padding="16,12"
                    FontSize="13" />
                <Button
                    Content="⚙  Settings"
                    Click="BtnSettings_Click"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    Foreground="#D1D5DB"
                    BorderThickness="0"
                    Padding="16,12"
                    FontSize="13" />
                <Border Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="#3A3A3A">
                    <TextBlock
                        Text="{x:Bind AppState.CameraRootPath, Mode=OneWay, FallbackValue='No library selected'}"
                        FontSize="11"
                        Foreground="#6B7280"
                        TextTrimming="CharacterEllipsis"
                        ToolTipService.ToolTip="{x:Bind AppState.CameraRootPath, Mode=OneWay}" />
                </Border>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════ CENTER PANEL ═══════════════════════════ -->
        <Grid Grid.Column="1" Background="#1A1A1A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Grid Grid.Row="0" Padding="12,8" ColumnSpacing="8" Background="#1F1F1F">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>

                <!-- View mode toggle -->
                <SelectorBar
                    Grid.Column="0"
                    x:Name="ViewModeSelector"
                    SelectionChanged="ViewModeSelector_SelectionChanged"
                    VerticalAlignment="Center">
                    <SelectorBarItem x:Name="SbiEdited" Text="Edited" />
                    <SelectorBarItem x:Name="SbiOriginals" Text="Originals" />
                </SelectorBar>

                <!-- Vertical separator -->
                <Border
                    Grid.Column="1"
                    Width="1"
                    Background="#3A3A3A"
                    Margin="4,6" />

                <!-- Session name -->
                <TextBlock
                    Grid.Column="2"
                    Text="{x:Bind AppState.SelectedSession.DisplayName, Mode=OneWay, FallbackValue='Select a session'}"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#F5F5F5"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis" />

                <!-- Zoom slider -->
                <Slider
                    Grid.Column="3"
                    x:Name="ZoomSlider"
                    Minimum="80" Maximum="200"
                    Value="140"
                    VerticalAlignment="Center"
                    ValueChanged="ZoomSlider_ValueChanged"
                    Foreground="{StaticResource AmberBrush}" />

                <!-- Enrich Selected -->
                <Button
                    Grid.Column="4"
                    Content="Enrich Selected"
                    Click="BtnEnrichSelected_Click"
                    IsEnabled="{x:Bind AppState.IsEnriching, Mode=OneWay, Converter={StaticResource BoolNegation}}"
                    Style="{StaticResource OutlineButtonStyle}"
                    FontSize="12" />

                <!-- Enrich All -->
                <Button
                    Grid.Column="5"
                    Content="Enrich All"
                    Click="BtnEnrichAll_Click"
                    IsEnabled="{x:Bind AppState.IsEnriching, Mode=OneWay, Converter={StaticResource BoolNegation}}"
                    Style="{StaticResource AccentButtonStyle}"
                    FontSize="12" />

                <!-- Session notes -->
                <TextBox
                    Grid.Column="6"
                    x:Name="TbSessionNotes"
                    PlaceholderText="Session notes for AI..."
                    Text="{x:Bind AppState.SessionNotes, Mode=TwoWay}"
                    Background="#2D2D2D"
                    BorderBrush="#3A3A3A"
                    Foreground="#F5F5F5"
                    FontSize="12"
                    TextChanged="TbSessionNotes_TextChanged" />
            </Grid>

            <!-- Photo grid area -->
            <Grid Grid.Row="1">
                <!-- Loading overlay -->
                <StackPanel
                    Visibility="{x:Bind AppState.IsLoadingPhotos, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16"
                    Canvas.ZIndex="10">
                    <ProgressRing IsActive="True" Width="48" Height="48" Foreground="{StaticResource AmberBrush}" />
                    <TextBlock Text="Loading photos..." Foreground="#9CA3AF" />
                </StackPanel>

                <!-- Enrichment progress banner -->
                <Border
                    Visibility="{x:Bind AppState.IsEnriching, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="#1F1F1F"
                    BorderBrush="#FFB938"
                    BorderThickness="0,0,0,2"
                    Padding="16,10"
                    Canvas.ZIndex="20">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressRing IsActive="True" Width="20" Height="20" Foreground="{StaticResource AmberBrush}" />
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock FontSize="13" Foreground="#F5F5F5">
                                <Run Text="Enriching" />
                                <Run Text="{x:Bind AppState.EnrichmentDone, Mode=OneWay}" />
                                <Run Text="of" />
                                <Run Text="{x:Bind AppState.EnrichmentTotal, Mode=OneWay}" />
                                <Run Text="—" />
                                <Run Text="{x:Bind AppState.EnrichmentCurrentFile, Mode=OneWay}" Foreground="#9CA3AF" />
                            </TextBlock>
                            <ProgressBar
                                Minimum="0"
                                Maximum="{x:Bind AppState.EnrichmentTotal, Mode=OneWay}"
                                Value="{x:Bind AppState.EnrichmentDone, Mode=OneWay}"
                                Foreground="{StaticResource AmberBrush}"
                                Background="#3A3A3A"
                                Height="3" />
                        </StackPanel>
                        <Button
                            Grid.Column="2"
                            Content="Cancel"
                            Click="BtnCancelEnrich_Click"
                            Background="Transparent"
                            BorderBrush="#3A3A3A"
                            Foreground="#9CA3AF"
                            FontSize="12"
                            Padding="10,4" />
                    </Grid>
                </Border>

                <!-- Empty state -->
                <StackPanel
                    x:Name="EmptyState"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Visibility="Collapsed">
                    <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center" />
                    <TextBlock Text="Select a session to view photos" Foreground="#6B7280" FontSize="14" />
                </StackPanel>

                <!-- ScrollViewer for photo grid -->
                <ScrollViewer
                    x:Name="PhotoScrollViewer"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
                    <ItemsRepeater
                        x:Name="PhotosRepeater"
                        ItemsSource="{x:Bind AppState.Photos, Mode=OneWay}"
                        Margin="8">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                x:Name="PhotoGrid"
                                MinItemWidth="140"
                                MinItemHeight="140"
                                MinColumnSpacing="4"
                                MinRowSpacing="4" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:Photo">
                                <Border
                                    x:Name="PhotoCard"
                                    Background="#242424"
                                    CornerRadius="6"
                                    Margin="2"
                                    BorderThickness="2"
                                    BorderBrush="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource SelectedToBorderBrush}}"
                                    Tapped="PhotoCard_Tapped"
                                    DoubleTapped="PhotoCard_DoubleTapped"
                                    Tag="{x:Bind Id}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Thumbnail: bound to Photo.ThumbnailSource (set in code-behind,
                                             avoids ItemsRepeater container-recycling race) -->
                                        <Border CornerRadius="6,6,0,0" MinHeight="100">
                                            <Image
                                                Source="{x:Bind ThumbnailSource, Mode=OneWay}"
                                                Stretch="UniformToFill" />
                                        </Border>

                                        <!-- Enrichment badge -->
                                        <Ellipse
                                            Width="10" Height="10"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,4,4,0"
                                            Fill="{x:Bind IsEnriched, Converter={StaticResource IsEnrichedToColor}}" />

                                        <!-- Footer -->
                                        <Border Grid.Row="1" Padding="6,4" Background="#1E1E1E" CornerRadius="0,0,6,6">
                                            <Grid>
                                                <TextBlock
                                                    Text="{x:Bind FileName}"
                                                    FontSize="10"
                                                    Foreground="#9CA3AF"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Text="{x:Bind Meta.Rating, Converter={StaticResource RatingToStars}}"
                                                    HorizontalAlignment="Right"
                                                    FontSize="10"
                                                    Foreground="#FFB938" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════ RIGHT PANEL ═══════════════════════════ -->
        <Grid Grid.Column="2" Background="#1F1F1F">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="12,10" BorderThickness="0,0,0,1" BorderBrush="#3A3A3A">
                <TextBlock
                    x:Name="InspectorTitle"
                    Text="{x:Bind AppState.SelectedPhoto.FileName, Mode=OneWay, FallbackValue='No photo selected'}"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="#F5F5F5"
                    TextTrimming="CharacterEllipsis" />
            </Border>

            <!-- Single photo inspector -->
            <ScrollViewer
                x:Name="InspectorScroll"
                Grid.Row="1"
                VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SingleInspector" Padding="12" Spacing="12">

                    <!-- Preview image -->
                    <Border
                        CornerRadius="6"
                        Background="#242424"
                        MaxHeight="260">
                        <Image
                            x:Name="PreviewImage"
                            Stretch="Uniform"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>

                    <!-- Metadata form -->
                    <StackPanel Spacing="10">

                        <!-- Title -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Title" Foreground="#9CA3AF" FontSize="11" />
                            <TextBox
                                x:Name="TbTitle"
                                PlaceholderText="Enter title..."
                                Background="#2D2D2D"
                                BorderBrush="#3A3A3A"
                                Foreground="#F5F5F5"
                                FontSize="13" />
                        </StackPanel>

                        <!-- Description -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Description" Foreground="#9CA3AF" FontSize="11" />
                            <TextBox
                                x:Name="TbDescription"
                                PlaceholderText="Enter description..."
                                Background="#2D2D2D"
                                BorderBrush="#3A3A3A"
                                Foreground="#F5F5F5"
                                FontSize="13"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                MinHeight="80" />
                        </StackPanel>

                        <!-- Keywords -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Keywords (comma-separated)" Foreground="#9CA3AF" FontSize="11" />
                            <TextBox
                                x:Name="TbKeywords"
                                PlaceholderText="nature, landscape, sunset..."
                                Background="#2D2D2D"
                                BorderBrush="#3A3A3A"
                                Foreground="#F5F5F5"
                                FontSize="13" />
                        </StackPanel>

                        <!-- Location -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Location" Foreground="#9CA3AF" FontSize="11" />
                            <TextBox
                                x:Name="TbLocation"
                                PlaceholderText="City, Country"
                                Background="#2D2D2D"
                                BorderBrush="#3A3A3A"
                                Foreground="#F5F5F5"
                                FontSize="13" />
                        </StackPanel>

                        <!-- Rating -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Rating" Foreground="#9CA3AF" FontSize="11" />
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button x:Name="Star1" Content="★" Tag="1" Click="StarButton_Click" Background="Transparent" Foreground="#9CA3AF" Padding="2" FontSize="20" />
                                <Button x:Name="Star2" Content="★" Tag="2" Click="StarButton_Click" Background="Transparent" Foreground="#9CA3AF" Padding="2" FontSize="20" />
                                <Button x:Name="Star3" Content="★" Tag="3" Click="StarButton_Click" Background="Transparent" Foreground="#9CA3AF" Padding="2" FontSize="20" />
                                <Button x:Name="Star4" Content="★" Tag="4" Click="StarButton_Click" Background="Transparent" Foreground="#9CA3AF" Padding="2" FontSize="20" />
                                <Button x:Name="Star5" Content="★" Tag="5" Click="StarButton_Click" Background="Transparent" Foreground="#9CA3AF" Padding="2" FontSize="20" />
                                <Button Content="✕" Tag="0" Click="StarButton_Click" Background="Transparent" Foreground="#6B7280" Padding="4,2" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Creator -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Creator" Foreground="#9CA3AF" FontSize="11" />
                            <TextBox
                                x:Name="TbCreator"
                                PlaceholderText="Creator name..."
                                Background="#2D2D2D"
                                BorderBrush="#3A3A3A"
                                Foreground="#F5F5F5"
                                FontSize="13" />
                        </StackPanel>

                        <!-- Copyright -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Copyright" Foreground="#9CA3AF" FontSize="11" />
                            <TextBox
                                x:Name="TbCopyright"
                                PlaceholderText="© 2026 Name"
                                Background="#2D2D2D"
                                BorderBrush="#3A3A3A"
                                Foreground="#F5F5F5"
                                FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="#3A3A3A" Margin="0,4" />

                    <!-- Camera info (read-only) -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Camera Info" Foreground="#9CA3AF" FontSize="11" FontWeight="SemiBold" />

                        <Grid x:Name="CameraInfoGrid" ColumnSpacing="8" RowSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Date" Foreground="#6B7280" FontSize="11" />
                            <TextBlock x:Name="LblDate" Grid.Row="0" Grid.Column="1" Foreground="#9CA3AF" FontSize="11" Text="—" />

                            <TextBlock Grid.Row="1" Text="Camera" Foreground="#6B7280" FontSize="11" />
                            <TextBlock x:Name="LblCamera" Grid.Row="1" Grid.Column="1" Foreground="#9CA3AF" FontSize="11" Text="—" TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="2" Text="Focal" Foreground="#6B7280" FontSize="11" />
                            <TextBlock x:Name="LblFocal" Grid.Row="2" Grid.Column="1" Foreground="#9CA3AF" FontSize="11" Text="—" />

                            <TextBlock Grid.Row="3" Text="Aperture" Foreground="#6B7280" FontSize="11" />
                            <TextBlock x:Name="LblAperture" Grid.Row="3" Grid.Column="1" Foreground="#9CA3AF" FontSize="11" Text="—" />

                            <TextBlock Grid.Row="4" Text="Shutter" Foreground="#6B7280" FontSize="11" />
                            <TextBlock x:Name="LblShutter" Grid.Row="4" Grid.Column="1" Foreground="#9CA3AF" FontSize="11" Text="—" />

                            <TextBlock Grid.Row="5" Text="ISO" Foreground="#6B7280" FontSize="11" />
                            <TextBlock x:Name="LblIso" Grid.Row="5" Grid.Column="1" Foreground="#9CA3AF" FontSize="11" Text="—" />

                            <TextBlock Grid.Row="6" Text="GPS" Foreground="#6B7280" FontSize="11" />
                            <TextBlock x:Name="LblGps" Grid.Row="6" Grid.Column="1" Foreground="#9CA3AF" FontSize="11" Text="—" TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="7" Text="Location" Foreground="#6B7280" FontSize="11" />
                            <TextBlock x:Name="LblLocationSrc" Grid.Row="7" Grid.Column="1" Foreground="#9CA3AF" FontSize="11" Text="—" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom buttons -->
            <Grid Grid.Row="2" Padding="12,10" ColumnSpacing="8" BorderThickness="0,1,0,0" BorderBrush="#3A3A3A">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button
                    Content="Save"
                    HorizontalAlignment="Stretch"
                    Click="BtnSave_Click"
                    Style="{StaticResource AccentButtonStyle}" />
                <Button
                    Grid.Column="1"
                    Content="Enrich"
                    Click="BtnEnrichSingle_Click"
                    IsEnabled="{x:Bind AppState.IsEnriching, Mode=OneWay, Converter={StaticResource BoolNegation}}"
                    Style="{StaticResource OutlineButtonStyle}" />
            </Grid>
        </Grid>
    </Grid>
</Page>
