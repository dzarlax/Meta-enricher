<ContentDialog
    x:Class="MetaEnricher.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    RequestedTheme="Dark"
    Background="#242424"
    MinWidth="480">

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
        <StackPanel Spacing="20" Padding="4">

            <!-- Library -->
            <StackPanel Spacing="10">
                <TextBlock Text="LIBRARY" Foreground="#9CA3AF" FontSize="11" FontWeight="SemiBold" />

                <StackPanel Spacing="6">
                    <TextBlock Text="Camera Root Folder" Foreground="#F5F5F5" FontSize="13" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="TbLibraryPath"
                            Foreground="#9CA3AF"
                            FontSize="12"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis" />
                        <Button
                            Grid.Column="1"
                            Content="Browse"
                            Click="BtnBrowseLibrary_Click"
                            Style="{StaticResource OutlineButtonStyle}"
                            FontSize="12" />
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Picks Subfolder Name" Foreground="#F5F5F5" FontSize="13" />
                    <TextBox
                        x:Name="TbPicksFolder"
                        Background="#2D2D2D"
                        BorderBrush="#3A3A3A"
                        Foreground="#F5F5F5"
                        FontSize="13" />
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="#3A3A3A" />

            <!-- Ollama -->
            <StackPanel Spacing="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="OLLAMA" Foreground="#9CA3AF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse x:Name="OllamaStatusDot" Width="8" Height="8" Fill="#6B7280" />
                        <TextBlock x:Name="TbOllamaStatus" Text="Unknown" Foreground="#9CA3AF" FontSize="11" />
                    </StackPanel>
                </Grid>

                <StackPanel Spacing="4">
                    <TextBlock Text="Ollama URL" Foreground="#F5F5F5" FontSize="13" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="TbOllamaUrl"
                            Background="#2D2D2D"
                            BorderBrush="#3A3A3A"
                            Foreground="#F5F5F5"
                            FontSize="13" />
                        <Button
                            Grid.Column="1"
                            Content="Test"
                            Click="BtnTestOllama_Click"
                            Background="Transparent"
                            Foreground="#9CA3AF"
                            BorderBrush="#3A3A3A"
                            FontSize="12"
                            Padding="10,6" />
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Model" Foreground="#F5F5F5" FontSize="13" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            x:Name="CbModel"
                            Background="#2D2D2D"
                            BorderBrush="#3A3A3A"
                            Foreground="#F5F5F5"
                            FontSize="13"
                            HorizontalAlignment="Stretch" />
                        <Button
                            Grid.Column="1"
                            Content="Refresh"
                            Click="BtnRefreshModels_Click"
                            Background="Transparent"
                            Foreground="#9CA3AF"
                            BorderBrush="#3A3A3A"
                            FontSize="12"
                            Padding="10,6" />
                    </Grid>
                </StackPanel>

                <!-- Pull model -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Pull a Model" Foreground="#F5F5F5" FontSize="13" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="TbPullModel"
                            PlaceholderText="e.g. qwen2.5vl"
                            Background="#2D2D2D"
                            BorderBrush="#3A3A3A"
                            Foreground="#F5F5F5"
                            FontSize="13" />
                        <Button
                            Grid.Column="1"
                            Content="Pull"
                            Click="BtnPullModel_Click"
                            Style="{StaticResource OutlineButtonStyle}"
                            FontSize="12" />
                    </Grid>
                    <ProgressBar
                        x:Name="PullProgress"
                        Visibility="Collapsed"
                        Minimum="0" Maximum="1"
                        Foreground="{StaticResource AmberBrush}"
                        Background="#3A3A3A" />
                    <TextBlock
                        x:Name="TbPullStatus"
                        Visibility="Collapsed"
                        Foreground="#9CA3AF"
                        FontSize="11" />
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="#3A3A3A" />

            <!-- Metadata defaults -->
            <StackPanel Spacing="10">
                <TextBlock Text="METADATA DEFAULTS" Foreground="#9CA3AF" FontSize="11" FontWeight="SemiBold" />

                <StackPanel Spacing="4">
                    <TextBlock Text="Default Creator" Foreground="#F5F5F5" FontSize="13" />
                    <TextBox
                        x:Name="TbDefaultCreator"
                        PlaceholderText="Your name..."
                        Background="#2D2D2D"
                        BorderBrush="#3A3A3A"
                        Foreground="#F5F5F5"
                        FontSize="13" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Default Copyright" Foreground="#F5F5F5" FontSize="13" />
                    <TextBox
                        x:Name="TbDefaultCopyright"
                        PlaceholderText="© 2026 Your Name"
                        Background="#2D2D2D"
                        BorderBrush="#3A3A3A"
                        Foreground="#F5F5F5"
                        FontSize="13" />
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="#3A3A3A" />

            <!-- Cache -->
            <StackPanel Spacing="10">
                <TextBlock Text="CACHE" Foreground="#9CA3AF" FontSize="11" FontWeight="SemiBold" />
                <Button
                    Content="Clear Thumbnail Cache"
                    Click="BtnClearCache_Click"
                    Background="#2D2D2D"
                    Foreground="#9CA3AF"
                    BorderBrush="#3A3A3A"
                    FontSize="13"
                    Padding="12,8" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
