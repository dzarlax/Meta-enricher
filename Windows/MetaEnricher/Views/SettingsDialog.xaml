<ContentDialog
    x:Class="MetaEnricher.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    RequestedTheme="Dark"
    Background="#242424">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">660</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">660</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600" Padding="0,0,16,0">
        <StackPanel Spacing="20" Padding="4,4,4,8">

            <!-- Library -->
            <StackPanel Spacing="10">
                <TextBlock Text="LIBRARY" Foreground="#9CA3AF" FontSize="11" FontWeight="SemiBold" />

                <StackPanel Spacing="6">
                    <TextBlock Text="Camera Root Folder" Foreground="#F5F5F5" FontSize="13" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="TbLibraryPath"
                            Foreground="#9CA3AF"
                            FontSize="12"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis" />
                        <Button
                            Grid.Column="1"
                            Content="Browse"
                            Click="BtnBrowseLibrary_Click"
                            Style="{StaticResource OutlineButtonStyle}"
                            FontSize="12" />
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Picks Subfolder Name" Foreground="#F5F5F5" FontSize="13" />
                    <TextBox
                        x:Name="TbPicksFolder"
                        Background="#2D2D2D"
                        BorderBrush="#3A3A3A"
                        Foreground="#F5F5F5"
                        FontSize="13" />
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="#3A3A3A" />

            <!-- Ollama -->
            <StackPanel Spacing="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="OLLAMA" Foreground="#9CA3AF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <SelectorBar
                        Grid.Column="1"
                        x:Name="OllamaModeSelector"
                        SelectionChanged="OllamaModeSelector_SelectionChanged"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <SelectorBarItem x:Name="SbiLocal" Text="Local" />
                        <SelectorBarItem x:Name="SbiCloud" Text="Cloud" />
                    </SelectorBar>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse x:Name="OllamaStatusDot" Width="8" Height="8" Fill="#6B7280" />
                        <TextBlock x:Name="TbOllamaStatus" Text="Unknown" Foreground="#9CA3AF" FontSize="11" />
                    </StackPanel>
                </Grid>

                <!-- Local: custom URL -->
                <StackPanel x:Name="LocalUrlPanel" Spacing="6">
                    <!-- Install hint -->
                    <Border Background="#1E2A3A" BorderBrush="#2A3B52" BorderThickness="1" CornerRadius="6" Padding="12,10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Run Ollama locally" Foreground="#F5F5F5" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11">
                                <Run Text="1. Download Ollama from " />
                                <Hyperlink NavigateUri="https://ollama.com/download/windows" Foreground="#FFB938">ollama.com/download</Hyperlink>
                                <LineBreak />
                                <Run Text="2. Install and run it — it auto-starts on " />
                                <Run Text="localhost:11434" FontFamily="Consolas" Foreground="#D1D5DB" />
                                <LineBreak />
                                <Run Text="3. Pull a vision model (see below) — recommended: " />
                                <Run Text="qwen2.5vl" FontFamily="Consolas" Foreground="#D1D5DB" />
                                <Run Text=" or " />
                                <Run Text="qwen3-vl" FontFamily="Consolas" Foreground="#D1D5DB" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Ollama URL" Foreground="#F5F5F5" FontSize="13" Margin="0,4,0,0" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="TbOllamaUrl"
                            Background="#2D2D2D"
                            BorderBrush="#3A3A3A"
                            Foreground="#F5F5F5"
                            FontSize="13" />
                        <Button
                            Grid.Column="1"
                            x:Name="BtnTestLocal"
                            Content="Test"
                            Click="BtnTestOllama_Click"
                            Background="Transparent"
                            Foreground="#9CA3AF"
                            BorderBrush="#3A3A3A"
                            FontSize="12"
                            Padding="10,6" />
                    </Grid>
                </StackPanel>

                <!-- Cloud: API key -->
                <StackPanel x:Name="CloudKeyPanel" Spacing="6" Visibility="Collapsed">
                    <!-- Cloud setup hint -->
                    <Border Background="#1E2A3A" BorderBrush="#2A3B52" BorderThickness="1" CornerRadius="6" Padding="12,10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Use Ollama Cloud" Foreground="#F5F5F5" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11">
                                <Run Text="1. Sign up at " />
                                <Hyperlink NavigateUri="https://ollama.com" Foreground="#FFB938">ollama.com</Hyperlink>
                                <LineBreak />
                                <Run Text="2. Open " />
                                <Hyperlink NavigateUri="https://ollama.com/settings/keys" Foreground="#FFB938">Settings → API Keys</Hyperlink>
                                <Run Text=" and create a new key" />
                                <LineBreak />
                                <Run Text="3. Paste it below — works with cloud-hosted vision models" />
                                <LineBreak />
                                <Run Text="Docs: " />
                                <Hyperlink NavigateUri="https://docs.ollama.com/cloud" Foreground="#FFB938">docs.ollama.com/cloud</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="API Key" Foreground="#F5F5F5" FontSize="13" Margin="0,4,0,0" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox
                            x:Name="TbApiKey"
                            PlaceholderText="Paste your Ollama Cloud API key..."
                            Background="#2D2D2D"
                            BorderBrush="#3A3A3A"
                            Foreground="#F5F5F5"
                            FontSize="13" />
                        <Button
                            Grid.Column="1"
                            x:Name="BtnTestCloud"
                            Content="Test"
                            Click="BtnTestOllama_Click"
                            Background="Transparent"
                            Foreground="#9CA3AF"
                            BorderBrush="#3A3A3A"
                            FontSize="12"
                            Padding="10,6" />
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Model" Foreground="#F5F5F5" FontSize="13" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            x:Name="CbModel"
                            Background="#2D2D2D"
                            BorderBrush="#3A3A3A"
                            Foreground="#F5F5F5"
                            FontSize="13"
                            HorizontalAlignment="Stretch" />
                        <Button
                            Grid.Column="1"
                            Content="Refresh"
                            Click="BtnRefreshModels_Click"
                            Background="Transparent"
                            Foreground="#9CA3AF"
                            BorderBrush="#3A3A3A"
                            FontSize="12"
                            Padding="10,6" />
                        <Button
                            Grid.Column="2"
                            x:Name="BtnUnload"
                            Content="Unload"
                            ToolTipService.ToolTip="Unload model from memory"
                            Click="BtnUnloadModel_Click"
                            Background="Transparent"
                            Foreground="#9CA3AF"
                            BorderBrush="#3A3A3A"
                            FontSize="12"
                            Padding="10,6" />
                    </Grid>
                </StackPanel>

                <!-- Pull model -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Pull a Model" Foreground="#F5F5F5" FontSize="13" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="TbPullModel"
                            PlaceholderText="e.g. qwen2.5vl"
                            Background="#2D2D2D"
                            BorderBrush="#3A3A3A"
                            Foreground="#F5F5F5"
                            FontSize="13" />
                        <Button
                            Grid.Column="1"
                            Content="Pull"
                            Click="BtnPullModel_Click"
                            Style="{StaticResource OutlineButtonStyle}"
                            FontSize="12" />
                    </Grid>
                    <ProgressBar
                        x:Name="PullProgress"
                        Visibility="Collapsed"
                        Minimum="0" Maximum="1"
                        Foreground="{StaticResource AmberBrush}"
                        Background="#3A3A3A" />
                    <TextBlock
                        x:Name="TbPullStatus"
                        Visibility="Collapsed"
                        Foreground="#9CA3AF"
                        FontSize="11" />
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="#3A3A3A" />

            <!-- Metadata defaults -->
            <StackPanel Spacing="10">
                <TextBlock Text="METADATA DEFAULTS" Foreground="#9CA3AF" FontSize="11" FontWeight="SemiBold" />

                <StackPanel Spacing="4">
                    <TextBlock Text="Default Creator" Foreground="#F5F5F5" FontSize="13" />
                    <TextBox
                        x:Name="TbDefaultCreator"
                        PlaceholderText="Your name..."
                        Background="#2D2D2D"
                        BorderBrush="#3A3A3A"
                        Foreground="#F5F5F5"
                        FontSize="13" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Default Copyright" Foreground="#F5F5F5" FontSize="13" />
                    <TextBox
                        x:Name="TbDefaultCopyright"
                        PlaceholderText="© 2026 Your Name"
                        Background="#2D2D2D"
                        BorderBrush="#3A3A3A"
                        Foreground="#F5F5F5"
                        FontSize="13" />
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="#3A3A3A" />

            <!-- ExifTool -->
            <StackPanel Spacing="10">
                <TextBlock Text="EXIFTOOL" Foreground="#9CA3AF" FontSize="11" FontWeight="SemiBold" />
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse x:Name="ExifToolDot" Width="8" Height="8" Fill="#EF4444" VerticalAlignment="Center" />
                    <TextBlock x:Name="TbExifToolStatus"
                               Grid.Column="1"
                               Foreground="#9CA3AF"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </Grid>
            </StackPanel>

            <Border Height="1" Background="#3A3A3A" />

            <!-- Cache -->
            <StackPanel Spacing="10">
                <TextBlock Text="CACHE" Foreground="#9CA3AF" FontSize="11" FontWeight="SemiBold" />
                <Button
                    Content="Clear Thumbnail Cache"
                    Click="BtnClearCache_Click"
                    Background="#2D2D2D"
                    Foreground="#9CA3AF"
                    BorderBrush="#3A3A3A"
                    FontSize="13"
                    Padding="12,8" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
