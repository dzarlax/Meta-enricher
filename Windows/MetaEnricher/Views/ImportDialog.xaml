<ContentDialog
    x:Class="MetaEnricher.Views.ImportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Import Photos"
    CloseButtonText="Close"
    RequestedTheme="Dark"
    Background="#242424"
    MinWidth="440">

    <StackPanel Spacing="16" Padding="4">

        <!-- Source drive -->
        <StackPanel Spacing="6">
            <TextBlock Text="Source Drive (with DCIM folder)" Foreground="#F5F5F5" FontSize="13" />
            <ComboBox
                x:Name="CbDrives"
                HorizontalAlignment="Stretch"
                Background="#2D2D2D"
                BorderBrush="#3A3A3A"
                Foreground="#F5F5F5"
                PlaceholderText="Select drive..." />
        </StackPanel>

        <!-- Destination -->
        <StackPanel Spacing="6">
            <TextBlock Text="Destination (Library Root)" Foreground="#F5F5F5" FontSize="13" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="TbDestPath"
                    Foreground="#9CA3AF"
                    FontSize="12"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis" />
                <Button
                    Grid.Column="1"
                    Content="Browse"
                    Click="BtnBrowseDest_Click"
                    Style="{StaticResource OutlineButtonStyle}"
                    FontSize="12" />
            </Grid>
        </StackPanel>

        <!-- Progress -->
        <StackPanel x:Name="ProgressPanel" Spacing="8" Visibility="Collapsed">
            <ProgressBar
                x:Name="ImportProgressBar"
                Minimum="0" Maximum="1"
                Foreground="{StaticResource AmberBrush}"
                Background="#3A3A3A" />
            <TextBlock
                x:Name="TbImportStatus"
                Foreground="#9CA3AF"
                FontSize="12"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                x:Name="TbImportCount"
                Foreground="#9CA3AF"
                FontSize="11" />
        </StackPanel>

        <!-- Error -->
        <TextBlock
            x:Name="TbError"
            Foreground="#EF4444"
            FontSize="12"
            Visibility="Collapsed"
            TextWrapping="Wrap" />

        <!-- Actions -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button
                x:Name="BtnCancel"
                Content="Cancel"
                Click="BtnCancel_Click"
                Visibility="Collapsed"
                Background="#2D2D2D"
                Foreground="#9CA3AF"
                BorderBrush="#3A3A3A" />
            <Button
                x:Name="BtnImport"
                Content="Start Import"
                Click="BtnImport_Click"
                Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
