<ContentDialog
    x:Class="MetaEnricher.Views.ImportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MetaEnricher.Models"
    Title="Import Photos"
    CloseButtonText="Close"
    RequestedTheme="Dark"
    Background="#242424">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">580</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">580</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560" Padding="0,0,12,0">
        <StackPanel Spacing="16" Padding="4">

            <!-- Source -->
            <StackPanel Spacing="8">
                <TextBlock Text="Source" Foreground="#F5F5F5" FontSize="13" />

                <SelectorBar
                    x:Name="SourceModeSelector"
                    SelectionChanged="SourceModeSelector_SelectionChanged">
                    <SelectorBarItem x:Name="SbiCard"   Text="From camera card" />
                    <SelectorBarItem x:Name="SbiFolder" Text="From folder" />
                </SelectorBar>

                <!-- Mode: camera card -->
                <StackPanel x:Name="CardModePanel" Spacing="4">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            x:Name="CbDrives"
                            HorizontalAlignment="Stretch"
                            Background="#2D2D2D"
                            BorderBrush="#3A3A3A"
                            Foreground="#F5F5F5"
                            PlaceholderText="Select drive..."
                            SelectionChanged="CbDrives_SelectionChanged" />
                        <Button
                            Grid.Column="1"
                            Content="Scan"
                            x:Name="BtnScanCard"
                            Click="BtnScan_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            FontSize="12" />
                    </Grid>
                    <TextBlock
                        x:Name="TbCardHint"
                        Foreground="#9CA3AF"
                        FontSize="11"
                        TextWrapping="Wrap"
                        Text="Insert an SD card, phone, or camera. Looks for a DCIM folder on each removable drive." />
                </StackPanel>

                <!-- Mode: folder -->
                <StackPanel x:Name="FolderModePanel" Spacing="4" Visibility="Collapsed">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="TbFolderPath"
                            Foreground="#9CA3AF"
                            FontSize="12"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis"
                            Text="No folder selected" />
                        <Button
                            Grid.Column="1"
                            Content="Select folder…"
                            x:Name="BtnBrowseSource"
                            Click="BtnBrowseSource_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            FontSize="12" />
                        <Button
                            Grid.Column="2"
                            Content="Scan"
                            x:Name="BtnScanFolder"
                            Click="BtnScan_Click"
                            Style="{StaticResource OutlineButtonStyle}"
                            IsEnabled="False"
                            FontSize="12" />
                    </Grid>
                    <TextBlock
                        Foreground="#9CA3AF"
                        FontSize="11"
                        TextWrapping="Wrap"
                        Text="Pick a folder that already holds your photos (e.g. on this PC, a network share, or a phone mounted in File Explorer)." />
                </StackPanel>
            </StackPanel>

            <!-- Destination -->
            <StackPanel Spacing="6">
                <TextBlock Text="Destination (Library Root)" Foreground="#F5F5F5" FontSize="13" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="TbDestPath"
                        Foreground="#9CA3AF"
                        FontSize="12"
                        VerticalAlignment="Center"
                        TextTrimming="CharacterEllipsis" />
                    <Button
                        Grid.Column="1"
                        Content="Browse"
                        Click="BtnBrowseDest_Click"
                        Background="Transparent"
                        Foreground="#9CA3AF"
                        BorderBrush="#3A3A3A"
                        FontSize="12"
                        Padding="10,6" />
                </Grid>
            </StackPanel>

            <!-- Scan result summary -->
            <StackPanel x:Name="ScanSummaryPanel" Spacing="10" Visibility="Collapsed">
                <Border Height="1" Background="#3A3A3A" />

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="TbNewCount" FontSize="22" FontWeight="SemiBold" Foreground="#FFB938" />
                        <TextBlock Text="new files to copy" FontSize="11" Foreground="#9CA3AF" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock x:Name="TbAlreadyCount" FontSize="22" FontWeight="SemiBold" Foreground="#6B7280" />
                        <TextBlock Text="already copied" FontSize="11" Foreground="#6B7280" />
                    </StackPanel>
                </Grid>

                <!-- Destination preview -->
                <TextBlock x:Name="TbDestPreview" FontSize="11" Foreground="#6B7280" TextWrapping="Wrap" />

                <!-- Thumbnail grid of new files -->
                <TextBlock Text="Files to import:" Foreground="#9CA3AF" FontSize="11" />
                <ScrollViewer
                    x:Name="ThumbScrollViewer"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    MaxHeight="200">
                    <ItemsRepeater x:Name="ThumbRepeater" Margin="0,0,0,4">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                MinItemWidth="72"
                                MinItemHeight="72"
                                MinColumnSpacing="4"
                                MinRowSpacing="4" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:Photo">
                                <Border CornerRadius="4" Background="#2D2D2D" Width="72" Height="72">
                                    <Image
                                        Source="{x:Bind ThumbnailSource, Mode=OneWay}"
                                        Stretch="UniformToFill" />
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </StackPanel>

            <!-- Scanning indicator -->
            <StackPanel x:Name="ScanningPanel" Spacing="8" Visibility="Collapsed"
                        HorizontalAlignment="Center">
                <ProgressRing IsActive="True" Width="32" Height="32" Foreground="{StaticResource AmberBrush}" />
                <TextBlock Text="Scanning card..." Foreground="#9CA3AF" FontSize="12" />
            </StackPanel>

            <!-- Copy progress -->
            <StackPanel x:Name="ProgressPanel" Spacing="8" Visibility="Collapsed">
                <Border Height="1" Background="#3A3A3A" />
                <ProgressBar
                    x:Name="ImportProgressBar"
                    Minimum="0" Maximum="1"
                    Foreground="{StaticResource AmberBrush}"
                    Background="#3A3A3A" />
                <TextBlock
                    x:Name="TbImportStatus"
                    Foreground="#9CA3AF"
                    FontSize="12"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    x:Name="TbImportCount"
                    Foreground="#9CA3AF"
                    FontSize="11" />
            </StackPanel>

            <!-- Error -->
            <TextBlock
                x:Name="TbError"
                Foreground="#EF4444"
                FontSize="12"
                Visibility="Collapsed"
                TextWrapping="Wrap" />

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button
                    x:Name="BtnCancelImport"
                    Content="Cancel"
                    Click="BtnCancelImport_Click"
                    Visibility="Collapsed"
                    Background="#2D2D2D"
                    Foreground="#9CA3AF"
                    BorderBrush="#3A3A3A" />
                <Button
                    x:Name="BtnImport"
                    Content="Import"
                    IsEnabled="False"
                    Click="BtnImport_Click"
                    Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
